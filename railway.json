{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacks": {
      "phases": {
        "setup": {
          "nix_dependencies": ["nodejs_18"]
        },
        "install": {
          "command": "npm install"
        }
      }
    }
  },
  "deploy": {
    "startCommand": "node server.js",
    "healthcheckPath": "/",
    "healthcheckPort": 5000
  }
}
